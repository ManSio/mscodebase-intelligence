# ═══════════════════════════════════════════════════════════
# MSCodeBase Intelligence v2.4.4 — Конфигурация
# ═══════════════════════════════════════════════════════════
# Загружается АВТОМАТИЧЕСКИ из .env при старте MCP-сервера.
# Можно не указывать — используются значения по умолчанию.
# Полный список: src/core/config.py
# ═══════════════════════════════════════════════════════════

# ─── Провайдер эмбеддингов ──────────────────────────────
# Система определяет провайдера АВТОМАТИЧЕСКИ в порядке:
#   1. LM Studio (http://127.0.0.1:1234)
#   2. Ollama (http://127.0.0.1:11434)
#   3. ONNX (встроенный, без внешних зависимостей)
# Достаточно просто запустить LM Studio — код сам найдёт.
# Принудительно указать Ollama:
# EMBEDDING_PROVIDER=ollama

# Хост/порт LM Studio
# LM_STUDIO_HOST=127.0.0.1
# LM_STUDIO_PORT=1234

# Хост/порт Ollama
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# Модель эмбеддинга (используется как имя при запросе к API)
# MODEL_NAME=text-embedding-bge-m3
# Размерность векторов (должна совпадать с моделью)
# EMBEDDING_DIMENSION=1024

# ─── Поиск ──────────────────────────────────────────────
# Провайдеры реранкинга (порядок приоритета, через запятую)
# RERANKER_PROVIDERS=ollama,lm_studio
# Лимиты результатов
# DEFAULT_SEARCH_LIMIT=6
# MAX_SEARCH_RESULTS=20
# Длина preview текста в результатах (символов)
# MAX_CHUNK_PREVIEW_LEN=800

# ─── Индексация ─────────────────────────────────────────
# Директория для индексных файлов (создаётся в корне проекта)
# BASE_INDEX_DIR=.codebase_indices
# Версия формата LanceDB
# LANCEDB_VERSION=v2
# Размер одного чанка и перекрытие между чанками (символы)
# CHUNK_SIZE=512
# CHUNK_OVERLAP=100
# Размер батча при индексации (чанков за один проход эмбеддера)
# INDEX_BATCH_SIZE=100
# Максимум одновременных запросов к эмбеддеру
# MAX_CONCURRENT_EMBEDDINGS=2

# ─── Производительность ─────────────────────────────────
# Таймауты (секунды)
# EMBEDDING_TIMEOUT=240.0
# RERANKER_TIMEOUT=180.0
# PROVIDER_PING_TIMEOUT=0.5
# Количество повторов при ошибках
# MAX_RETRIES=3
# Задержка между повторами (секунды)
# RETRY_DELAY=1.0

# ─── Безопасность ───────────────────────────────────────
# Максимальный размер файла для индексации (мегабайты)
# MAX_FILE_SIZE_MB=10
# Разрешённые расширения (через запятую)
# ALLOWED_EXTENSIONS=.py,.rs,.ts,.jsx,.tsx,.js,.go,.java,.md

# ─── Логирование ────────────────────────────────────────
# Уровень: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
