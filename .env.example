╔═══════════════════════════════════════════════════════════════╗
║     MSCodeBase Intelligence — Environment Configuration      ║
║              v2.7.0  |  2026-07-07                           ║
╚═══════════════════════════════════════════════════════════════╝
# Copy this file to .env and edit as needed.
# Скопируйте в .env и отредактируйте при необходимости.
# All variables have sensible defaults — .env is only for overrides.
# Все переменные имеют разумные значения по умолчанию.

# ─── EMBEDDING PROVIDER ─────────────────────────────────────
# EN: Embedding strategy: auto (first available), lm_studio, onnx, ollama
# RU: Стратегия эмбеддингов: auto (первый доступный), lm_studio, onnx, ollama
# EMBEDDING_PROVIDER=auto
#
# EN: Embedding model: qwen3-embedding (default, best quality) or bge-m3 (faster indexing)
# RU: Модель эмбеддинга: qwen3-embedding (по умолчанию, лучшее качество) или bge-m3 (быстрее)
# EMBEDDING_MODEL=qwen3-embedding

# ─── LLAMA.CPP (локальный движок GGUF) ──────────────────────
# EN: Host and port for the local llama-server
# RU: Хост и порт для локального llama-server
# LLAMA_CPP_HOST=127.0.0.1
# LLAMA_CPP_PORT=8080
#
# EN: Context window for embeddings (1024 = 722 MB RAM for Qwen3, 692 MB for BGE-M3)
# RU: Размер контекста (1024 = 722 MB RAM для Qwen3, 692 MB для BGE-M3)
# LLAMA_CTX_SIZE=1024
#
# EN: Batch size for embedding (max tokens per pass)
# RU: Размер батча (макс токенов за проход)
# LLAMA_BATCH_SIZE=512
#
# EN: Physical batch size for CPU (lower = less RAM, higher = faster)
# RU: Физический размер батча для CPU
# LLAMA_UBATCH_SIZE=128

# ─── ONNX SERVER (fallback если нет GGUF) ────────────────────
# EN: Host and port for the ONNX inference server
# RU: Хост и порт для ONNX сервера
# ONNX_SERVER_HOST=127.0.0.1
# ONNX_SERVER_PORT=1235

# ─── LM STUDIO (OpenAI-compatible API) ──────────────────────
# EN: Host and port for LM Studio local API server
# RU: Хост и порт локального API-сервера LM Studio
# LM_STUDIO_HOST=127.0.0.1
# LM_STUDIO_PORT=1234
#
# EN: Model name for embeddings (loaded in LM Studio)
# RU: Название модели для эмбеддингов (загружена в LM Studio)
# MODEL_NAME=text-embedding-bge-m3
#
# EN: Embedding vector dimension (BGE-M3 = 1024, MiniLM = 384)
# RU: Размерность вектора эмбеддинга (BGE-M3 = 1024, MiniLM = 384)
# EMBEDDING_DIMENSION=1024
#
# EN: LM Studio default API key (sk-local is the built-in key)
# RU: Ключ API LM Studio по умолчанию (sk-local — встроенный)
# API_KEY=sk-local

# ─── OLLAMA ─────────────────────────────────────────────────
# EN: Host and port for Ollama local server
# RU: Хост и порт локального сервера Ollama
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# ─── MCP SERVER ─────────────────────────────────────────────
# EN: Host and port for the MCP stdio-to-SSE bridge
# RU: Хост и порт для MCP stdio-to-SSE моста
# MCP_HOST=127.0.0.1
# MCP_PORT=8765

# ─── LSP SERVER ─────────────────────────────────────────────
# EN: Host for the LSP language server
# RU: Хост для LSP-сервера (языковой сервер)
# LSP_HOST=127.0.0.1

# ─── SEARCH ─────────────────────────────────────────────────
# EN: Default number of search results returned
# RU: Количество результатов поиска по умолчанию
# DEFAULT_SEARCH_LIMIT=6
#
# EN: Hard cap on maximum search results (prevents overload)
# RU: Жёсткий лимит максимальных результатов поиска
# MAX_SEARCH_RESULTS=20
#
# EN: Truncate chunk text previews to this length
# RU: Обрезать предпросмотр чанка до этой длины
# MAX_CHUNK_PREVIEW_LEN=800
#
# EN: Comma-separated reranker providers (ollama, lm_studio)
# RU: Провайдеры реранкера через запятую (ollama, lm_studio)
# RERANKER_PROVIDERS=ollama,lm_studio
#
# EN: Enable query expansion via synonyms
# RU: Включить расширение запроса синонимами
# QUERY_SYNONYMS_ENABLED=true
#
# EN: Max number of synonym expansions per query
# RU: Максимальное количество синонимов на запрос
# MAX_QUERY_EXPANSIONS=3

# ─── INDEXING ───────────────────────────────────────────────
# EN: Base directory for LanceDB index storage
# RU: Базовая директория для хранения индексов LanceDB
# BASE_INDEX_DIR=.codebase_indices
#
# EN: LanceDB storage version (v2 is current)
# RU: Версия хранения LanceDB (v2 — актуальная)
# LANCEDB_VERSION=v2
#
# EN: Number of characters per text chunk
# RU: Количество символов в одном текстовом чанке
# CHUNK_SIZE=512
#
# EN: Overlap between consecutive chunks (sliding window)
# RU: Перекрытие между соседними чанками (скользящее окно)
# CHUNK_OVERLAP=100
#
# EN: Number of chunks per batch write to LanceDB
# RU: Количество чанков в одной пачке записи в LanceDB
# INDEX_BATCH_SIZE=100
#
# EN: Max concurrent embedding requests to LM Studio
# RU: Максимум параллельных запросов эмбеддинга к LM Studio
# MAX_CONCURRENT_EMBEDDINGS=2
#
# EN: How often (seconds) to scan for available providers
# RU: Как часто (секунд) сканировать доступные провайдеры
# PROVIDER_SCAN_INTERVAL=30

# ─── TIMEOUTS ───────────────────────────────────────────────
# EN: Embedding request timeout (seconds). Large batches need more.
# RU: Таймаут запроса эмбеддинга (секунд). Большим пачкам нужно больше.
# EMBEDDING_TIMEOUT=240.0
#
# EN: Reranker request timeout (seconds)
# RU: Таймаут запроса реранкера (секунд)
# RERANKER_TIMEOUT=180.0
#
# EN: Provider ping timeout (seconds) — quick health check
# RU: Таймаут пинга провайдера (секунд) — быстрая проверка здоровья
# PROVIDER_PING_TIMEOUT=0.5

# ─── PERFORMANCE ────────────────────────────────────────────
# EN: Disable ONNX Runtime fallback entirely (use only llama.cpp/Qwen3)
# RU: Полное отключение ONNX Runtime (только llama.cpp/Qwen3)
# DISABLE_ONNX_FALLBACK=false
# EN: Max async worker threads for CPU-bound tasks
# RU: Максимум асинхронных воркеров для CPU-задач
# MAX_ASYNC_WORKERS=10
#
# EN: Max retry attempts for failed operations
# RU: Максимум попыток повтора для упавших операций
# MAX_RETRIES=3
#
# EN: Delay between retries (seconds)
# RU: Задержка между повторами (секунд)
# RETRY_DELAY=1.0
#
# EN: Max retry attempts for file I/O operations
# RU: Максимум попыток повтора для файловых операций
# FILE_RETRY_MAX_ATTEMPTS=3
#
# EN: Delay between file I/O retries (seconds)
# RU: Задержка между повторами файловых операций (секунд)
# FILE_RETRY_DELAY=0.05
#
# EN: Startup delay before MCP server begins (seconds)
# RU: Задержка перед запуском MCP-сервера (секунд)
# MCP_STARTUP_DELAY=1.0

# ─── MULTI-BUCKET RAG ───────────────────────────────────────
# EN: Overfetch factor — how many extra results to fetch before reranking
# RU: Коэффициент переполучения — сколько лишних результатов запрашивать до реранкинга
# OVERFETCH_FACTOR=3
#
# EN: Soft weight multiplier for code bucket (1.0 = neutral)
# RU: Множитель веса для корзины кода (1.0 = нейтрально)
# CODE_BUCKET_WEIGHT=1.0
#
# EN: Soft weight multiplier for docs bucket (1.0 = neutral)
# RU: Множитель веса для корзины документации (1.0 = нейтрально)
# DOCS_BUCKET_WEIGHT=1.0

# ─── SYSTEM PROFILE ─────────────────────────────────────────
# EN: System profile: 'light' (no phi-4) or 'server' (full RAG with phi-4)
# RU: Профиль системы: 'light' (без phi-4) или 'server' (полный RAG с phi-4)
# SYSTEM_PROFILE=light

# ─── MODE=ASK (RAG generation via phi-4) ────────────────────
# EN: Timeout for phi-4 response generation (seconds)
# RU: Таймаут генерации ответа phi-4 (секунд)
# ASK_TIMEOUT=60.0
#
# EN: LLM model name for mode=ask responses
# RU: Название LLM модели для режима mode=ask
# ASK_MODEL=phi-4-mini-instruct

# ─── SECURITY ───────────────────────────────────────────────
# EN: Maximum file size (MB) allowed for indexing
# RU: Максимальный размер файла (МБ) для индексации
# MAX_FILE_SIZE_MB=10
#
# EN: Comma-separated list of allowed file extensions
# RU: Список разрешённых расширений файлов через запятую
# ALLOWED_EXTENSIONS=.py,.rs,.ts,.jsx,.tsx,.js,.go,.java,.cpp,.c,.h,.hpp,.php,.rb,.md,.json,.yaml,.yml,.toml
#
# EN: Follow symlinks during file scanning
# RU: Следовать симлинкам при сканировании файлов
# ALLOW_SYMLINKS=true
#
# EN: Reject paths with suspicious components (.., ~, UNC)
# RU: Отклонять пути с подозрительными компонентами (.., ~, UNC)
# STRICT_PATH_VALIDATION=true

# ─── LOGGING ────────────────────────────────────────────────
# EN: Log level: DEBUG, INFO, WARNING, ERROR
# RU: Уровень логирования: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ─── LOCALISATION ───────────────────────────────────────────
# EN: Interface language: en, ru, zh
# RU: Язык интерфейса: en, ru, zh
# MSCODEBASE_LOCALE=en

# ─── LSP CLIENT ─────────────────────────────────────────────
# EN: Request timeout (seconds) for LSP rename/references
#     Increase on slow machines or large projects
# RU: Таймаут запроса (секунды) для LSP rename/references
#     Увеличьте на медленных машинах или больших проектах
# LSP_REQUEST_TIMEOUT=5.0
#
# EN: Server startup timeout (seconds), increase on slow machines
# RU: Таймаут запуска LSP-сервера (секунды), увеличьте на медленных машинах
# LSP_START_TIMEOUT=10.0

# ─── EXECUTE SCRIPT (RCE risk) ──────────────────────────────
# EN: Enable ExecuteScriptTool (Python code execution via LLM).
#     DISABLED by default — this is a host-based executor with NO sandbox.
#     Only enable if you understand the RCE risk from prompt injection.
# RU: Включить ExecuteScriptTool (выполнение Python-кода через LLM).
#     ОТКЛЮЧЁН по умолчанию — выполняется на хосте БЕЗ изоляции.
#     Включайте только если понимаете риск RCE через prompt injection.
# MSCODEBASE_EXECUTE_SCRIPT_ENABLED=false
