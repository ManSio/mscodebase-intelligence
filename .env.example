# MSCodebase Intelligence — Конфигурация
# Скопируйте в .env и отредактируйте при необходимости

# Путь к проекту (обычно определяется автоматически)
# PROJECT_PATH=.

# Директории для модели и индекса
# MODEL_DIR=.codebase_models
# INDEX_DIR=.codebase_index

# Провайдер эмбеддингов: onnx | ollama | openai
# EMBEDDING_PROVIDER=onnx

# Имя модели для эмбеддингов
# MODEL_NAME=all-MiniLM-L6-v2

# Для внешних API (Ollama, LM Studio, OpenAI)
# API_BASE_URL=http://localhost:11434
# API_KEY=sk-local

# Размер батча для обработки файлов
# BATCH_SIZE=32

# Отслеживание изменений файлов
# WATCH_ENABLED=true

# Авто-индексация при старте (отключите для больших проектов)
# AUTO_INDEX=true

# Уровень логирования: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
