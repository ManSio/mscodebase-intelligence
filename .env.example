# ═══════════════════════════════════════════════════════════
# MSCodeBase Intelligence v2.4.4 — Конфигурация
# ═══════════════════════════════════════════════════════════
# Скопируйте в .env и отредактируйте при необходимости.
# Большинство параметров имеют разумные значения по умолчанию.
# Полный список всех опций: src/core/config.py
# ═══════════════════════════════════════════════════════════

# ─── Провайдер эмбеддингов ──────────────────────────────
# Система определяет провайдера АВТОМАТИЧЕСКИ в порядке:
#   1. LM Studio (http://127.0.0.1:1234)
#   2. Ollama (http://127.0.0.1:11434)
#   3. ONNX (встроенный, без внешних зависимостей)
# Ручная настройка не требуется, но при желании:

# LM_STUDIO_HOST=127.0.0.1
# LM_STUDIO_PORT=1234
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# Имя модели для эмбеддингов (используется как fallback)
# MODEL_NAME=text-embedding-bge-m3
# EMBEDDING_DIMENSION=1024

# ─── Поиск ──────────────────────────────────────────────
# Провайдеры реранкинга (порядок приоритета)
# RERANKER_PROVIDERS=ollama,lm_studio
# Лимиты результатов
# DEFAULT_SEARCH_LIMIT=6
# MAX_SEARCH_RESULTS=20

# ─── Индексация ─────────────────────────────────────────
# Директория для индексных файлов (per-project)
# BASE_INDEX_DIR=.codebase_indices
# Размер чанка и перекрытие (символы)
# CHUNK_SIZE=512
# CHUNK_OVERLAP=100
# Батчи для производительности
# INDEX_BATCH_SIZE=100
# MAX_CONCURRENT_EMBEDDINGS=2

# ─── Производительность ─────────────────────────────────
# Таймауты (секунды)
# EMBEDDING_TIMEOUT=240.0
# RERANKER_TIMEOUT=180.0
# PROVIDER_PING_TIMEOUT=0.5
# Повторы при ошибках
# MAX_RETRIES=3
# RETRY_DELAY=1.0

# ─── Безопасность ───────────────────────────────────────
# Максимальный размер файла для индексации (MB)
# MAX_FILE_SIZE_MB=10
# Разрешённые расширения (через запятую)
# ALLOWED_EXTENSIONS=.py,.rs,.ts,.jsx,.tsx,.js,.go,.java,.md

# ─── Пути (Windows compat) ──────────────────────────────
# PROJECT_PATH — задаётся автоматически через LSP→MCP bridge.
# Если bridge не работает (ZED_WORKTREE_ROOT не установлен):
#   1. Открой любой .py файл в проекте → LSP запустится → bridge запишет
#   2. Или установи PROJECT_PATH в .zed/settings.json проекта:
#      { "context_servers": { "mscodebase-intelligence": { "env": { "PROJECT_PATH": "." } } } }
#   3. Или передавай project_root параметром в каждый инструмент
# PROJECT_PATH=.
