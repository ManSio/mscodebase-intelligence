# ═══════════════════════════════════════════════════════════════
# MSCodeBase Intelligence — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Скопируйте в .env и отредактируйте при необходимости.
# Все переменные имеют разумные значения по умолчанию — .env
# нужен только для переопределения.

# ─── Провайдер эмбеддингов ────────────────────────────────────
# Определяет стратегию выбора: auto (первый доступный: LM Studio > ONNX > Ollama)
# Можно принудительно: "lm_studio" | "onnx" | "ollama"
# EMBEDDING_PROVIDER=auto

# ─── LM Studio (OpenAI-совместимый API) ──────────────────────
# LM_STUDIO_HOST=127.0.0.1
# LM_STUDIO_PORT=1234
# MODEL_NAME=text-embedding-bge-m3
# EMBEDDING_DIMENSION=1024
# API_KEY=sk-local

# ─── Ollama ───────────────────────────────────────────────────
# OLLAMA_HOST=127.0.0.1
# OLLAMA_PORT=11434

# ─── Сервер ──────────────────────────────────────────────────
# MCP_HOST=127.0.0.1
# MCP_PORT=8765
# LSP_HOST=127.0.0.1

# ─── Поиск ───────────────────────────────────────────────────
# DEFAULT_SEARCH_LIMIT=6
# MAX_SEARCH_RESULTS=20
# MAX_CHUNK_PREVIEW_LEN=800
# RERANKER_PROVIDERS=ollama,lm_studio
# QUERY_SYNONYMS_ENABLED=true
# MAX_QUERY_EXPANSIONS=3

# ─── Индексация ─────────────────────────────────────────────
# BASE_INDEX_DIR=.codebase_indices
# LANCEDB_VERSION=v2
# CHUNK_SIZE=512
# CHUNK_OVERLAP=100
# INDEX_BATCH_SIZE=100
# MAX_CONCURRENT_EMBEDDINGS=2
# PROVIDER_SCAN_INTERVAL=30

# ─── Таймауты ────────────────────────────────────────────────
# EMBEDDING_TIMEOUT=240.0
# RERANKER_TIMEOUT=180.0
# PROVIDER_PING_TIMEOUT=0.5

# ─── Производительность ─────────────────────────────────────
# MAX_ASYNC_WORKERS=10
# MAX_RETRIES=3
# RETRY_DELAY=1.0
# FILE_RETRY_MAX_ATTEMPTS=3
# FILE_RETRY_DELAY=0.05
# MCP_STARTUP_DELAY=1.0

# ─── Безопасность ────────────────────────────────────────────
# MAX_FILE_SIZE_MB=10
# ALLOWED_EXTENSIONS=.py,.rs,.ts,.jsx,.tsx,.js,.go,.java,.cpp,.c,.h,.hpp,.php,.rb,.md,.json,.yaml,.yml,.toml
# ALLOW_SYMLINKS=true
# STRICT_PATH_VALIDATION=true

# ─── Логирование ─────────────────────────────────────────────
# LOG_LEVEL=INFO
