# ═══════════════════════════════════════════════════════════
# MSCodeBase Intelligence v2.4.4 — Локальная конфигурация
# ═══════════════════════════════════════════════════════════
# Раскомментируй и измени при необходимости.
# Все опции с дефолтами можно не указывать.

# ─── Провайдер эмбеддингов ──────────────────────────────
# Автоопределение: LM Studio → Ollama → ONNX
# Достаточно просто запустить LM Studio на порту 1234
# MODEL_NAME=text-embedding-bge-m3

# ─── Индексация ─────────────────────────────────────────
# Размер батча для пакетной обработки (чанки за один проход)
# INDEX_BATCH_SIZE=100
# Максимум одновременных эмбеддингов
# MAX_CONCURRENT_EMBEDDINGS=2

# ─── Поиск ──────────────────────────────────────────────
# Количество результатов по умолчанию
# DEFAULT_SEARCH_LIMIT=6

# ─── Безопасность ───────────────────────────────────────
# Максимальный размер файла для индексации
MAX_FILE_SIZE_MB=5
