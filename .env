# ═══════════════════════════════════════════════════════════════
# MSCodeBase Intelligence — Environment (активные настройки)
# ═══════════════════════════════════════════════════════════════
# Полный список всех опций см. в .env.example

# ─── Провайдер эмбеддингов ───────────────────────────────────
# auto — авто-детект (LM Studio > ONNX > Ollama)
# EMBEDDING_PROVIDER=auto

# ─── Поиск ───────────────────────────────────────────────────
DEFAULT_SEARCH_LIMIT=6
MAX_SEARCH_RESULTS=20

# ─── Индексация ─────────────────────────────────────────────
INDEX_BATCH_SIZE=16
BASE_INDEX_DIR=.codebase_indices

# ─── Безопасность ────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ─── Логирование ─────────────────────────────────────────────
LOG_LEVEL=INFO
