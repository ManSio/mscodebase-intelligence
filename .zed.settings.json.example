{
  // MSCodeBase Intelligence — изкоробочная настройка для Zed
  // PROJECT_PATH = $ZED_WORKTREE_ROOT — Zed подставляет активный проект.
  // current_dir НЕ используется: $ZED_WORKTREE_ROOT не резолвится в нём (баг Zed #36019).
  // PYTHONPATH = корень расширения, чтобы import src.* работал.
  "context_servers": {
    "mscodebase-intelligence": {
      "command": "<python.exe>",
      "args": ["-u", "-m", "src.main"],
      "env": {
        "PROJECT_PATH": "$ZED_WORKTREE_ROOT",
        "PYTHONPATH": "<ext_install_dir>"
      }
    }
  },

  // Авто-запрос к серверу (как @codebase в Cursor)
  "context_servers_to_query": ["mscodebase-intelligence"],

  // LSP Server для проактивной индексации (Ctrl+S → обновление индекса).
  // Рекомендуется включить — без него MCP увидит изменения только при явном notify_change.
  "lsp": {
    "mscodebase-lsp": {
      "command": "<python.exe>",
      "arguments": ["-u", "<ext_install_dir>/src/lsp_main.py"],
      "env": {
        "PROJECT_PATH": "$ZED_WORKTREE_ROOT",
        "PYTHONPATH": "<ext_install_dir>"
      }
    }
  },

  // Привязка LSP к языкам — mscodebase-lsp работает как дополнение
  // к основному language-серверу (pyright, tsserver, rust-analyzer и т.п.)
  "languages": {
    "Python": { "language_servers": ["pyright", "mscodebase-lsp"] },
    "TypeScript": { "language_servers": ["typescript-language-server", "mscodebase-lsp"] },
    "JavaScript": { "language_servers": ["typescript-language-server", "mscodebase-lsp"] },
    "TSX": { "language_servers": ["typescript-language-server", "mscodebase-lsp"] },
    "Rust": { "language_servers": ["rust-analyzer", "mscodebase-lsp"] },
    "Go": { "language_servers": ["gopls", "mscodebase-lsp"] }
  }
}
